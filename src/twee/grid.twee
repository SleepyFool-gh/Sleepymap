        <div>R to teleport to Dining Room, only from Outhouse</div>
    </div>

    /* rose, <<do>> to toggle autoupdate */
    <div id='rose'>
        <<do tag 'rose'>>
            <<if _rose_autoupdate>>
                <div>This rose autoupdates.</div>
            <<else>>
                <div>This rose doesn't autoupdate.</div>
            <</if>>
            <<place_rose
                mapname     _mapname
                background  '<img src="./assets/rose.png">'
                autoupdate  _rose_autoupdate
            >>
        <</do>>
    </div>
</div></nowiki></code></pre><pre><code class="language-javascript"><nowiki>/* WASD controller */
<<set _keys = {
    w: { dir: 'N' },
    d: { dir: 'E' },
    s: { dir: 'S' },
    a: { dir: 'W' },
    e: { x: 2, y: 1 },
}>>
<<place_controller
    mapname     _mapname
    keys        _keys  
>>

/* controller for outhouse -> dining room */
<<do tag 'controller'>>
    <<run
        _pos = Sleepymap.get_mapstate({ mapname: _mapname, mapstate: 'position' });
        _enabled = _pos.mapnode === 'O';
        _keys = { r: { mapnode: 'D' } };
    >>
    <<place_controller
        mapname     _mapname
        keys        _keys
        enabled     _enabled
    >>
<</do>></nowiki></code></pre>