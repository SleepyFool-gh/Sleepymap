:: StoryTitle
Sleepymap Macro Library, Demo




:: StoryInit [nobr]
<!--
  ‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą   ‚Ėą ‚Ėą‚Ėą‚Ėą ‚Ėą    ‚Ėą ‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą
 ‚Ėą       ‚Ėą   ‚Ėą    ‚Ėą ‚Ėą   ‚Ėą  ‚Ėą ‚Ėą   ‚Ėą  ‚Ėą‚Ėą   ‚Ėą  ‚Ėą    ‚Ėą
  ‚Ėą‚Ėą‚Ėą    ‚Ėą   ‚Ėą    ‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą    ‚Ėą    ‚Ėą  ‚Ėą ‚Ėą  ‚Ėą  ‚Ėą    ‚Ėą
     ‚Ėą   ‚Ėą   ‚Ėą    ‚Ėą ‚Ėą   ‚Ėą   ‚Ėą    ‚Ėą  ‚Ėą  ‚Ėą ‚Ėą  ‚Ėą    ‚Ėą
 ‚Ėą‚Ėą‚Ėą‚Ėą    ‚Ėą    ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą   ‚Ėą   ‚Ėą   ‚Ėą‚Ėą‚Ėą ‚Ėą   ‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą   ‚Ėą
 SECTION: StoryInit
-->
/* define mapnodes */
<<set _mapnodes = {
    M: {name: 'Master Bedroom'},
    G: {name: 'Guest Bedroom'},
    H: {name: 'Hallway'},
    L: {name: 'Living Room'},
    S: {name: 'Stairs'},
    D: {name: 'Dining Room'},
    K: {name: 'Kitchen'},
    P: {name: 'Pantry'},
    O: {name: 'Outhouse'},
}>>

/* new node travel map */
<<new_map 
    mapname     'node_house'
    columns     16
    start       'D'
>>
    .   .   .   .   .   .   .   .    .   .   .   .   .   .    .   .
    .   .   O   .   K   K   K   K    K   .   L   L   L   L    L   .
    .   .   .   .   K   K   K   K    K   .   L   L   L   L    L   .
    .   P   P   P|  K_  K   K_  K_  _K   .   L   L_  L_  L_   L   .
    .   P   P   P|  D   D   D   D   |S   .   H  |G   G   G   |S   .
    .   P   P   P|  D   D   D   D   |S   .   H   G_  G_  G_ _|S   .
    .   P   P   P   D   D   D   D    D   .   H  |M   M   M    M   .
    .   P   P   P|  D   D   D   D    D   .   H   M   M   M    M   .
    .   .   .   .   .   .   .   .    .   .   .   .   .   .    .   .
<<mapnodes _mapnodes>>
<</new_map>>

/* new grid travel map */
<<new_map 
    mapname     'grid_house'
    columns     16
    grid_travel true
    start_x     4
    start_y     5
>>
    .   .   .   .   .   .   .   .    .   .   .   .   .   .    .   .
    .   .   O   .   K   K   K   K    K   .   L   L   L   L    L   .
    .   .   .   .   K   K   K   K    K   .   L   L   L   L    L   .
    .   P   P   P|  K_  K   K_  K_  _K   .   L   L_  L_  L_   L   .
    .   P   P   P|  D   D   D   D   |S   .   H  |G   G   G   |S   .
    .   P   P   P|  D   D   D   D   |S   .   H   G_  G_  G_ _|S   .
    .   P   P   P   D   D   D   D    D   .   H  |M   M   M    M   .
    .   P   P   P|  D   D   D   D    D   .   H   M   M   M    M   .
    .   .   .   .   .   .   .   .    .   .   .   .   .   .    .   .
<<mapnodes _mapnodes>>
<</new_map>>

/* init vars */
<<run
    $energy = 100;
    $heat = 0;
    $hunger = 0;
>>

<<for _mapname range ['node_house', 'grid_house']>>
    /* set scripts */
    <<set_mapscripts mapname _mapname>>
        /* decrement energy whenever a mapmove is attempted */
        <<onmapattempt>>
            <<set $energy-->>
        /* increase heat when moving around upstairs */
        <<onmapattempt to `['L', 'H', 'G', 'M']`>>
            <<set $heat++>>
        /* ring a bell when coming down the stairs */
        <<onmapstart from 'S' to 'D'>>
            <<run console.log('Ding!')>>
        /* increase hunger when entering the kitchen or pantry */
        <<onmapend from 'D' to `['K', 'P']`>>
            <<set $hunger++>>
        /* tell <<redo>> to run any time mapmove succeeds */
        <<onmapend>>
            <<redo 'stats'>>
    <</set_mapscripts>>

    /* place a kitty in dining room */
    <<new_entity 
        mapname     _mapname
        entityname  'kitty'
        x           7
        y           5
        tile        '<div id="kitty">ūüźĪ</div>'
    >>
<</for>>




:: Start [nobr]
<!--
  ‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą
 ‚Ėą       ‚Ėą   ‚Ėą   ‚Ėą ‚Ėą   ‚Ėą   ‚Ėą
  ‚Ėą‚Ėą‚Ėą    ‚Ėą   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą    ‚Ėą
     ‚Ėą   ‚Ėą   ‚Ėą   ‚Ėą ‚Ėą   ‚Ėą   ‚Ėą
 ‚Ėą‚Ėą‚Ėą‚Ėą    ‚Ėą   ‚Ėą   ‚Ėą ‚Ėą   ‚Ėą   ‚Ėą
 SECTION: Start
-->
<h2>Sleepymap, a SugarCube Macro Library for 2D Maps</h2>
<div>
    <div>
        <code>Sleepymap</code> is a map macro library for SugarCube which takes a space-separated 2D text grid (<code>maparray</code>) and converts it into a functional map for player movement (<code>mapmove</code>). It has two modes:
    </div>
    <ol>
        <li>
            <b><code>node travel</code>:</b> Node-to-node movement like <b>Faster Than Light</b> or room-to-room movement like <b>Darkest Dungeon</b>. All grid spaces with the same id will be treated as one big room (<code>mapnode</code>) ‚ÄĒ regardless of how many grid spaces it occupies or whether it is continuous or not. Adjacent <code>mapnode</code> will be connected by <code>exits</code> that allow navigation between them. Because <code>mapnode</code> size is irrelevant, multiple links to different rooms may appear in the same direction on the <code>rose</code> (default)
        </li>
        <li>
            <b><code>grid travel</code>:</b> Grid movement like <b>Zelda</b> or <b>Final Fantasy Tactics</b>. Adjacent grid spaces with the same id will inherit the same properties, but will need to be traversed through one grid space at a time. Each grid space is connected by <code>exits</code> to adjacent grid spaces it can reach. (set when creating a new map)
        </li>
    </ol>
    <p>
        <b>Note:</b> <code>mapmove</code> <i><b>DOES NOT</b></i> trigger passage navigation. Authors <b>must</b> navigate to save map changes to <code>State</code>.
    </p>
    <div>
        <a href='https://sleepyfool-gh.github.io/Sleepymap/'>Read the documentation here</a>
    </div>
    <div>
        <a href='https://github.com/SleepyFool-gh/areamap'>Get the map library here</a>
    </div>
</div>
<ul>
    <li>[[View the node travel demo -> node_house]]</li>
    <li>[[View the grid travel demo -> grid_house]]</li>
</ul>




:: node_house [nobr]
<!--
 ‚Ėą    ‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą       ‚Ėą   ‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą   ‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą
 ‚Ėą‚Ėą   ‚Ėą ‚Ėą    ‚Ėą ‚Ėą   ‚Ėą ‚Ėą           ‚Ėą   ‚Ėą ‚Ėą    ‚Ėą ‚Ėą   ‚Ėą ‚Ėą     ‚Ėą
 ‚Ėą ‚Ėą  ‚Ėą ‚Ėą    ‚Ėą ‚Ėą   ‚Ėą ‚Ėą‚Ėą‚Ėą         ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą    ‚Ėą ‚Ėą   ‚Ėą  ‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą
 ‚Ėą  ‚Ėą ‚Ėą ‚Ėą    ‚Ėą ‚Ėą   ‚Ėą ‚Ėą           ‚Ėą   ‚Ėą ‚Ėą    ‚Ėą ‚Ėą   ‚Ėą     ‚Ėą ‚Ėą
 ‚Ėą   ‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą   ‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą   ‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą
 SECTION: node house
-->
<<set 
    _mapname = 'node_house';
    _code_passage = 'node_code';
    _quickmove = false;
    _rose_autoupdate = true;
    _mapview_autoupdate = true;
>>
<h2>Node Travel ‚ÄĒ demo</h2>
<<include 'content'>>

/* master bedroom can be entered but not left */
<<disconnect_map
    mapname     _mapname
    from        'M'
    to          'H'
>>
/* move dining room to stairs connection from N/S to E/W */
<<disconnect_map
    mapname     _mapname
    from        'D'
    to          'S'
>>
<<disconnect_map
    mapname     _mapname
    from        'S'
    to          'D'
>>
<<connect_map
    mapname     _mapname
    from        'D'
    to          'S'
    direction   'E'
>>
<<connect_map
    mapname     _mapname
    from        'S'
    to          'D'
    direction   'W'
>>

:: node_code
