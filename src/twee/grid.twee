:: content [nobr]
<!--
  ████  ████  █    █ █████ █████ █    █ █████
 █     █    █ ██   █   █   █     ██   █   █
 █     █    █ █ █  █   █   ███   █ █  █   █
 █     █    █ █  █ █   █   █     █  █ █   █
  ████  ████  █   ██   █   █████ █   ██   █
 SECTION: content
-->
<style>
    #grid {
        display: grid;
        grid-template-columns: 1fr minmax(0, 60%);
        gap: 1rem;
    }
    #controls {
        --indent: 0.5rem;
        display:flex;
        flex-direction:column;
        text-indent: calc(-1 * var(--indent));
        margin-left: var(--indent);
    }
    #roses {
        margin-top: 0.5rem;
    }
    #story {
        margin-top: 0 !important;
    }
    #kitty {
        font-size: 1rem;
    }
    @media (max-width: 768px) {
        #grid {
            grid-template-columns: 1fr;
        }
        #controls {
            grid-row: 2;
        }
        #kitty {
            font-size: 0.7rem;
        }
        .macro-Sleepymap-tile { 
            --border-width: 0.1rem;
        }
    }
</style>

/* mapview, <<do>> for enabling/disabling autoupdate */
<<do tag 'mapview'>>
    <<if _mapview_autoupdate>>
        <div>This map autoupdates.</div>
    <<else>>
        <div>This map doesn't autoupdate.</div>
    <</if>>
    <<place_mapview
        mapname     _mapname
        background  '<img src="./assets/small_house.png">'
        autoupdate  _mapview_autoupdate
    >>
<</do>>

<div id='grid'>
    <div id='controls'>

        /* map stats */
        <h3>Map Info</h3>
        <<do tag 'stats'>>
            <div>Energy: $energy</div>
            <div>Heat: $heat</div>
            <div>Hunger: $hunger</div>
        <</do>>

        /* demo navigation */
        <h3>Navigation</h3>
        [[Return to travel mode selection -> Start]]
        <<link 'See the code for this passage' _code_passage>><</link>>
        <<link 'Navigate in place' _mapname>><</link>>
        <div>Use sidebar to navigate backwards or forwards.</div>

        /* mapmove controls */
        <h3>Map Controls</h3>
        <<link 'Go upstairs'>>
            <<mapmove mapname _mapname target_x 14  target_y 5>>
        <</link>>
        <<link 'Go downstairs'>>
            <<mapmove mapname _mapname target_x 8 target_y 4>>
        <</link>>
        <<link 'Go to guest bedroom'>>
            <<mapmove mapname _mapname target_mapnode 'G'>>
        <</link>>
        
        /* interface controls controls */
        <<do tag 'mapview'>>
            <<set _text = _mapview_autoupdate ? "Disable mapview autoupdate" : "Enable mapview autoupdate">>
            <<link _text>>
                <<set _mapview_autoupdate = ! _mapview_autoupdate>>
                <<redo 'mapview'>>
            <</link>>
        <</do>>
        <<do tag 'rose'>>
            <<set _text = _rose_autoupdate ? "Disable rose autoupdate" : "Enable rose autoupdate">>
            <<link _text>>
                <<set _rose_autoupdate = ! _rose_autoupdate>>
                <<redo 'rose'>>
            <</link>>
        <</do>>
        <<link 'Update interfaces'>>
            <<update_interface selector '.macro-Sleepymap-rose'>>
            <<update_interface selector '.macro-Sleepymap-mapview'>>
        <</link>>
        <div>WASD for north, east, south, west respectively.</div>
        <div>E to teleport to Outhouse</div>
        <div>R to teleport to Dining Room, only from Outhouse</div>
    </div>

    /* rose, <<do>> to toggle autoupdate */
    <div id='rose'>
        <<do tag 'rose'>>
            <<if _rose_autoupdate>>
                <div>This rose autoupdates.</div>
            <<else>>
                <div>This rose doesn't autoupdate.</div>
            <</if>>
            <<place_rose
                mapname     _mapname
                background  '<img src="./assets/rose.png">'
                autoupdate  _rose_autoupdate
            >>
        <</do>>
    </div>
</div>

/* WASD controller */
<<set _keys = {
    w: { dir: 'N' },
    d: { dir: 'E' },
    s: { dir: 'S' },
    a: { dir: 'W' },
    e: { x: 2, y: 1 },
}>>
<<place_controller
    mapname     _mapname
    keys        _keys  
>>

/* controller for outhouse -> dining room */
<<do tag 'controller'>>
    <<run
        _pos = Sleepymap.get_mapstate({ mapname: _mapname, mapstate: 'position' });
        _enabled = _pos.mapnode === 'O';
        _keys = { r: { mapnode: 'D' } };
    >>
    <<place_controller
        mapname     _mapname
        keys        _keys
        enabled     _enabled
    >>
<</do>>




