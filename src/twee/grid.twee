    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
<</nobr>><pre><code class="language-javascript"><nowiki>/* set scripts */
<<set_mapscripts mapname _mapname>>
    /* decrement energy whenever a mapmove is attempted */
    <<onmapattempt>>
        <<set $energy-->>
    /* increase heat when moving around upstairs */
    <<onmapattempt to `['L', 'H', 'G', 'M']`>>
        <<set $heat++>>
    /* ring a bell when coming down the stairs */
    <<onmapstart from 'S' to 'D'>>
        <<run console.log('Ding!')>>
    /* increase hunger when entering the kitchen or pantry */
    <<onmapend from 'D' to `['K', 'P']`>>
        <<set $hunger++>>
    /* <<redo>> update stats any time mapmove succeeds */
    <<onmapend>>
        <<redo 'stats'>>
<</set_mapscripts>></nowiki></code></pre><pre><code class="language-javascript"><nowiki>/* place a kitty in dining room */
<<new_entity 
    mapname     _mapname
    entityname  'kitty'
    x           7
    y           5
    tile        '<div id="kitty">ūüźĪ</div>'
>></nowiki></code></pre><h3>Passage Code</h3><pre><code class="language-javascript"><nowiki>/* place mapview, <<do>> for toggling autoupdate */
<<do tag 'mapview'>>
    <<if _mapview_autoupdate>>
        <div>This map autoupdates.</div>
    <<else>>
        <div>This map doesn't autoupdate.</div>
    <</if>>
    <<place_mapview
        mapname     _mapname
        background  '<img src="./assets/small_house.png">'
        autoupdate  _mapview_autoupdate
    >>
<</do>></nowiki></code></pre><pre><code class="language-javascript"><nowiki>/* place rose, <<do>> to toggling autoupdate */
<<do tag 'rose'>>
    <<if _rose_autoupdate>>
        <div>This rose autoupdates.</div>
    <<else>>
        <div>This rose doesn't autoupdate.</div>
    <</if>>
    <<place_rose
        mapname     _mapname
        background  '<img src="./assets/rose.png">'
        autoupdate  _rose_autoupdate
    >>
<</do>></nowiki></code></pre><pre><code class="language-javascript"><nowiki>/* map stats */
<h3>Map Info</h3>
<<do tag 'stats'>>
    <div>Energy: $energy</div>
    <div>Heat: $heat</div>
    <div>Hunger: $hunger</div>
<</do>></nowiki></code></pre><pre><code class="language-javascript"><nowiki>/* demo controls */
<h3>Navigation</h3>
[[Return to travel mode selection -> Start]]
<<link 'See the code for this demo' _code_passage>><</link>>
<<link 'Navigate in place' _mapname>><</link>>
<div>Use sidebar to navigate backwards or forwards.</div></nowiki></code></pre><pre><code class="language-javascript"><nowiki>/* mapmove controls */
<h3>Map Controls</h3>
<<link 'Go upstairs'>>
    <<mapmove mapname _mapname target_x 14  target_y 5>>
<</link>>
<<link 'Go downstairs'>>
    <<mapmove mapname _mapname target_x 8 target_y 4>>
<</link>>
<<link 'Go to guest bedroom'>>
    <<mapmove mapname _mapname target_mapnode 'G'>>
<</link>></nowiki></code></pre><pre><code class="language-javascript"><nowiki>/* interface controls */
<<do tag 'mapview'>>
    <<set _text = _mapview_autoupdate ? "Disable mapview autoupdate" : "Enable mapview autoupdate">>
    <<link _text>>
        <<set _mapview_autoupdate = ! _mapview_autoupdate>>
        <<redo 'mapview'>>
    <</link>>
<</do>>
<<do tag 'rose'>>
    <<set _text = _rose_autoupdate ? "Disable rose autoupdate" : "Enable rose autoupdate">>
    <<link _text>>
        <<set _rose_autoupdate = ! _rose_autoupdate>>
        <<redo 'rose'>>
    <</link>>
<</do>>
<<link 'Update interfaces'>>
    <<update_interface selector '.macro-Sleepymap-rose'>>
    <<update_interface selector '.macro-Sleepymap-mapview'>>
<</link>></nowiki></code></pre><pre><code class="language-javascript"><nowiki>/* WASD controller */
<<set _keys = {
    w: { dir: 'N' },
    d: { dir: 'E' },
    s: { dir: 'S' },
    a: { dir: 'W' },
    e: { x: 2, y: 1 },
}>>
<<place_controller
    mapname     _mapname
    keys        _keys  
>>

/* controller for outhouse -> dining room */
<<set _keys = { 
    r: { mapnode: 'D' }, 
}>>
<<place_controller
    mapname     _mapname
    keys        _keys
    enabled     "Sleepymap.get_mapstate({ mapname: _mapname }).mapnode === 'O'"
>></nowiki></code></pre>