:: grid_house [nobr]
<!--
  ███  ████  ███ ████        █   █  ████  █   █  ████ █████
 █     █   █  █  █   █       █   █ █    █ █   █ █     █
 █  ██ ████   █  █   █       █████ █    █ █   █  ███  ███
 █   █ █   █  █  █   █       █   █ █    █ █   █     █ █
  ███  █   █ ███ ████  █████ █   █  ████   ███  ████  █████
 SECTION: grid_house
-->
<<set 
    _mapname = 'grid_house';
    _code_passage = 'grid_code';
    _quickmove = true;
    _rose_autoupdate = true;
    _mapview_autoupdate = true;
>>
<h2>Grid Travel — demo</h2>
<<include 'content'>>

/* connect stairs */
<<connect_map
    mapname     _mapname
    from_x      8
    from_y      4
    to_x        14
    to_y        5
    direction   'N'
>>
<<connect_map
    mapname     _mapname
    from_x      14
    from_y      5
    to_x        8
    to_y        4
    direction   'S'
>>


