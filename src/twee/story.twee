:: StoryTitle
Walach Home - areamap demo


:: StoryInit [nobr]
 <<set 
    setup.areas = {
        GB  :   {name: 'Guest Bedroom'},
        UH  :   {name: 'Hallway'},
        LR  :   {name: 'Living Room'},
        KT  :   {name: 'Kitchen'},
        FY  :   {name: 'Foyer'},
        CY  :   {name: 'Courtyard'},
        LH  :   {name: 'Hallway'},
        WR  :   {name: 'Waiting Room'},
        PR  :   {name: 'Parlor'},
        MB  :   {name: 'Master Bedroom'},
        LB  :   {name: 'Laboratory'},
        "#" :   {name: '', type: 'wall'}
    };
>>


