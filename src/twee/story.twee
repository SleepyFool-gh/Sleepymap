<</new_areamap>>
<<set $position to 'CY'>>
<<set_areascripts mapname 'demo'>>
    <<onmapattempt to `['G', 'W']`>>
        <<run console.log('to G or W!')>>
    <<onmapstart to 'H'>>
        <<run console.log('to H!')>>
    <<onmapstart from 'D'>>
        <<run console.log('from D!')>>
    <<onmapend from any>>
        <<run console.log('from any!')>>
    <<onmapabort>>
        <<run console.log('aborted!')>>
<</set_areascripts>>

