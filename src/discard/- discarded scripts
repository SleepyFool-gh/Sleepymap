        const $dir = create_areamap_links({
            mapname,
            dir,
        });
        $dir.appendTo($rose);
    }

    $rose.on('click', '.macro-areamap-link', function(ev) {
        if (autoupdate) {
            $rose.replaceWith(create_areamap_rose(argObj));
        }
    });

    return $rose;
